say: "=== Math Functions ==="
say: abs(-5)
say: min(10, 3)
say: max(10, 3)
say: pow(2, 3)
say: sqrt(16)
say: "=== String Functions ==="
var text: "Hello World"
say: toupper(text)
say: tolower(text)
say: "=== Collection Functions ==="
var nums: [3, 1, 4]
say: nums
say: "=== Type Conversion ==="
say: str(123)
say: num("456")
say: "=== Done ==="
