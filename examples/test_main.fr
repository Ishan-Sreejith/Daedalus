import "test_plugin.mtro"

say: "→ Starting Metroman Import Test"

var success: metroman-test-plugin: "Ishan"

if success == 1 {
    say: "✓ Plugin function call returned successfully"
}

var math_result: calculate-extra: 5, 4
say: "→ Math result from plugin (5 * 4 + 10): "
say: math_result

if math_result == 30 {
    say: "✓ Plugin math test passed"
}
ask: "What is your name? "

say: "→ Metroman Test Project Finished"
